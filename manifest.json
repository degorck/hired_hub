{
  "manifest_version": 3,
  "name": "HiredHub",
  "version": "1.0.0",
  "description": "Track your job applications across platforms",
  "icons": {
    "16": "icon/icon-16.png",
    "32": "icon/icon-32.png",
    "48": "icon/icon-48.png",
    "128": "icon/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "HiredHub",
    "default_width": 450,
    "default_height": 700
  },
  "permissions": [
    "storage"
  ],
  "minimum_chrome_version": "108"
}
